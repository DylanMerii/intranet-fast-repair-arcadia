<!DOCTYPE html>
<h3>Créer utilisateur</h3>
<input id="newEmail" placeholder="Email">
<input id="newPass" placeholder="Password">
<select id="roleSelect">
<option value="user">Dépanneur</option>
<option value="chef">Chef</option>
<option value="admin">Admin</option>
</select>
<button onclick="createUser()">Créer</button>
</div>

</div>
</div>

<script>
const firebaseConfig={apiKey:"TA_CLE",authDomain:"APP.firebaseapp.com",projectId:"APP"}
firebase.initializeApp(firebaseConfig)
const auth=firebase.auth();const db=firebase.firestore();
let currentRole="user";

function login(){
auth.signInWithEmailAndPassword(email.value,password.value).then(()=>{
login.style.display='none';app.style.display='block';loadRole();loadAll();})}

function loadRole(){
db.collection("users").doc(auth.currentUser.uid).get().then(doc=>{
if(doc.exists) currentRole=doc.data().role;
if(currentRole!="admin") document.querySelector('[onclick="showPage(\'admin\')"]').style.display='none';
})}

function showPage(p){document.querySelectorAll('.page').forEach(x=>x.style.display='none');document.getElementById(p).style.display='block'}

function prendreService(){db.collection("service").add({user:auth.currentUser.email,start:Date.now()})}

function loadAll(){
setInterval(()=>{
db.collection("service").get().then(s=>{
serviceList.innerHTML='';tempsService.innerHTML='';let stats={}
s.forEach(doc=>{
let d=doc.data();let t=Math.floor((Date.now()-d.start)/60)
serviceList.innerHTML+=`<li>${d.user}</li>`
tempsService.innerHTML+=`<li>${d.user} - ${t} min</li>`
stats[d.user]=(stats[d.user]||0)+t
})
statsList.innerHTML=''
for(let u in stats){statsList.innerHTML+=`<li>${u} : ${stats[u]} min</li>`}
})
},2000)

// FOURRIERE LIVE
db.collection("fourriere").onSnapshot(s=>{
fourriereTable.innerHTML=''
s.forEach(doc=>{
let d=doc.data();
fourriereTable.innerHTML+=`<tr>
<td>${d.prop}</td>
<td>${d.vehicule}</td>
<td class="${d.statut}">${d.statut}</td>
<td>
<button onclick="edit('${doc.id}','${d.prop}','${d.vehicule}')">✏️</button>
<button onclick="supprimer('${doc.id}')">❌</button>
</td>
</tr>`})})

// ADMIN INFOS
db.collection("config").doc("info").onSnapshot(doc=>{if(doc.exists)infoText.innerText=doc.data().text})
}

function ajouterFourriere(){
db.collection("fourriere").add({prop:prop.value,vehicule:vehicule.value,date:date.value,destruction:destruction.value,statut:statut.value})}

function supprimer(id){db.collection("fourriere").doc(id).delete()}

function edit(id,p,v){let np=prompt("Nom",p);let nv=prompt("Vehicule",v);db.collection("fourriere").doc(id).update({prop:np,vehicule:nv})}

function search(){let val=search.value.toLowerCase();document.querySelectorAll('#fourriereTable tr').forEach(tr=>{tr.style.display=tr.innerText.toLowerCase().includes(val)?'':'none'})}

function saveInfo(){db.collection("config").doc("info").set({text:adminText.value})}

function createUser(){
auth.createUserWithEmailAndPassword(newEmail.value,newPass.value).then(cred=>{
db.collection("users").doc(cred.user.uid).set({role:roleSelect.value})})}
  
  const firebaseConfig = {
  apiKey: "1111ebb7667dd5624344761f47958c06ad700846",
  authDomain: "FAST_REPAIR_ARCADIA.firebaseapp.com",
  projectId: "fast-repair-arcadia",
};

// RESET DIMANCHE
setInterval(()=>{let d=new Date();if(d.getDay()==0&&d.getHours()==12&&d.getMinutes()==0){db.collection("service").get().then(s=>s.forEach(doc=>doc.ref.delete()))}},60000)
</script>

</body>
</html>

  <p>© 2026 Sapeurs Pompiers Arcadia</p>
</footer>

</body>
</html>
